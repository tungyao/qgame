#version 450
layout(local_size_x = 64) in;

layout(std430, binding = 0) buffer InputBuffer {
    uint input_data[];
};

layout(std430, binding = 1) buffer OutputBuffer {
    uint output_data[];
};

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx < 1024) {
        output_data[idx] = input_data[idx] * 2u;
    }
}
